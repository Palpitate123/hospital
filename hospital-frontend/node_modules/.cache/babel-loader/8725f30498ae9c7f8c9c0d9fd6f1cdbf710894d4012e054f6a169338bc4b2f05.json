{"ast":null,"code":"export default {\n  name: 'DoctorLayout',\n  data() {\n    return {\n      defaultAvatar: 'https://cube.elemecdn.com/3/7c/3ea6beec64369c2642b92c6726f1epng.png'\n    };\n  },\n  computed: {\n    activeMenu() {\n      return this.$route.path;\n    },\n    doctorInfo() {\n      return this.$store.state.user.userInfo || {};\n    }\n  },\n  methods: {\n    handleCommand(command) {\n      if (command === 'profile') {\n        this.$router.push('/doctor/profile');\n      } else if (command === 'logout') {\n        this.$store.dispatch('user/logout').then(() => {\n          this.$router.push('/login');\n        });\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","defaultAvatar","computed","activeMenu","$route","path","doctorInfo","$store","state","user","userInfo","methods","handleCommand","command","$router","push","dispatch","then"],"sources":["src/views/layout/DoctorLayout.vue"],"sourcesContent":["<template>\n  <el-container class=\"doctor-layout\">\n    <el-aside width=\"220px\" class=\"sidebar\">\n      <div class=\"logo\">\n        <i class=\"el-icon-first-aid-kit\"></i>\n        <span>医生工作台</span>\n      </div>\n      <el-menu\n        :default-active=\"activeMenu\"\n        class=\"sidebar-menu\"\n        background-color=\"#1e3a5f\"\n        text-color=\"#fff\"\n        active-text-color=\"#409EFF\"\n        router\n      >\n        <el-menu-item index=\"/doctor/dashboard\">\n          <i class=\"el-icon-s-home\"></i>\n          <span>工作台首页</span>\n        </el-menu-item>\n        <el-menu-item index=\"/doctor/schedule\">\n          <i class=\"el-icon-date\"></i>\n          <span>排班管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/doctor/appointments\">\n          <i class=\"el-icon-s-order\"></i>\n          <span>预约管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/doctor/profile\">\n          <i class=\"el-icon-user\"></i>\n          <span>个人信息</span>\n        </el-menu-item>\n      </el-menu>\n    </el-aside>\n    <el-container>\n      <el-header class=\"header\">\n        <div class=\"header-left\">\n          <span class=\"hospital-name\">{{ doctorInfo.hospitalName || '医院预约挂号系统' }}</span>\n        </div>\n        <div class=\"header-right\">\n          <el-dropdown @command=\"handleCommand\">\n            <span class=\"user-info\">\n              <el-avatar :size=\"36\" :src=\"doctorInfo.avatar || defaultAvatar\"></el-avatar>\n              <span class=\"user-name\">{{ doctorInfo.realName || doctorInfo.userName }}</span>\n              <i class=\"el-icon-arrow-down\"></i>\n            </span>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item command=\"profile\">个人中心</el-dropdown-item>\n              <el-dropdown-item command=\"logout\" divided>退出登录</el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n        </div>\n      </el-header>\n      <el-main class=\"main-content\">\n        <router-view></router-view>\n      </el-main>\n    </el-container>\n  </el-container>\n</template>\n\n<script>\nexport default {\n  name: 'DoctorLayout',\n  data() {\n    return {\n      defaultAvatar: 'https://cube.elemecdn.com/3/7c/3ea6beec64369c2642b92c6726f1epng.png'\n    }\n  },\n  computed: {\n    activeMenu() {\n      return this.$route.path\n    },\n    doctorInfo() {\n      return this.$store.state.user.userInfo || {}\n    }\n  },\n  methods: {\n    handleCommand(command) {\n      if (command === 'profile') {\n        this.$router.push('/doctor/profile')\n      } else if (command === 'logout') {\n        this.$store.dispatch('user/logout').then(() => {\n          this.$router.push('/login')\n        })\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.doctor-layout {\n  height: 100vh;\n}\n.sidebar {\n  background-color: #1e3a5f;\n}\n.logo {\n  height: 60px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #fff;\n  font-size: 18px;\n  font-weight: bold;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n.logo i {\n  font-size: 28px;\n  margin-right: 10px;\n  color: #409EFF;\n}\n.sidebar-menu {\n  border-right: none;\n}\n.header {\n  background: #fff;\n  box-shadow: 0 1px 4px rgba(0, 21, 41, 0.08);\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 0 20px;\n}\n.hospital-name {\n  font-size: 18px;\n  font-weight: 600;\n  color: #1e3a5f;\n}\n.user-info {\n  display: flex;\n  align-items: center;\n  cursor: pointer;\n}\n.user-name {\n  margin: 0 8px;\n  color: #333;\n}\n.main-content {\n  background: #f0f2f5;\n  padding: 20px;\n}\n</style>\n"],"mappings":"AA4DA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,aAAA;IACA;EACA;EACAC,QAAA;IACAC,WAAA;MACA,YAAAC,MAAA,CAAAC,IAAA;IACA;IACAC,WAAA;MACA,YAAAC,MAAA,CAAAC,KAAA,CAAAC,IAAA,CAAAC,QAAA;IACA;EACA;EACAC,OAAA;IACAC,cAAAC,OAAA;MACA,IAAAA,OAAA;QACA,KAAAC,OAAA,CAAAC,IAAA;MACA,WAAAF,OAAA;QACA,KAAAN,MAAA,CAAAS,QAAA,gBAAAC,IAAA;UACA,KAAAH,OAAA,CAAAC,IAAA;QACA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}