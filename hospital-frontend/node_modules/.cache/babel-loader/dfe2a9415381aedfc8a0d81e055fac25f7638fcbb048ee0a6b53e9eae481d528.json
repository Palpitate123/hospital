{"ast":null,"code":"import { mapGetters, mapActions } from 'vuex';\nexport default {\n  name: 'PatientLayout',\n  computed: {\n    ...mapGetters(['token', 'username', 'nickName']),\n    activeMenu() {\n      return this.$route.path;\n    }\n  },\n  methods: {\n    ...mapActions('user', ['logout']),\n    handleCommand(command) {\n      if (command === 'logout') {\n        this.$confirm('确定要退出登录吗？', '提示', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        }).then(async () => {\n          await this.logout();\n          this.$router.push('/home');\n        }).catch(() => {});\n      } else if (command === 'orders') {\n        this.$router.push('/my-orders');\n      } else if (command === 'profile') {\n        this.$router.push('/profile');\n      }\n    }\n  }\n};","map":{"version":3,"names":["mapGetters","mapActions","name","computed","activeMenu","$route","path","methods","handleCommand","command","$confirm","confirmButtonText","cancelButtonText","type","then","logout","$router","push","catch"],"sources":["src/views/layout/PatientLayout.vue"],"sourcesContent":["<template>\n  <div class=\"patient-layout\">\n    <el-header class=\"patient-header\">\n      <div class=\"header-content\">\n        <div class=\"logo-section\">\n          <router-link to=\"/home\" class=\"logo-link\">\n            <i class=\"el-icon-first-aid-kit logo-icon\"></i>\n            <span class=\"logo-text\">医院预约挂号系统</span>\n          </router-link>\n        </div>\n        \n        <el-menu\n          :default-active=\"activeMenu\"\n          mode=\"horizontal\"\n          background-color=\"transparent\"\n          text-color=\"#333\"\n          active-text-color=\"#409EFF\"\n          router\n          class=\"nav-menu\"\n        >\n          <el-menu-item index=\"/home\">首页</el-menu-item>\n          <el-menu-item index=\"/department\">科室导航</el-menu-item>\n          <el-menu-item index=\"/doctor\">医生团队</el-menu-item>\n        </el-menu>\n        \n        <div class=\"user-section\">\n          <template v-if=\"token\">\n            <el-dropdown @command=\"handleCommand\">\n              <span class=\"user-info\">\n                <el-avatar :size=\"32\" icon=\"el-icon-user-solid\"></el-avatar>\n                <span class=\"username\">{{ nickName || username }}</span>\n                <i class=\"el-icon-arrow-down\"></i>\n              </span>\n              <el-dropdown-menu slot=\"dropdown\">\n                <el-dropdown-item icon=\"el-icon-document\" command=\"orders\">我的预约</el-dropdown-item>\n                <el-dropdown-item icon=\"el-icon-user\" command=\"profile\">个人中心</el-dropdown-item>\n                <el-dropdown-item icon=\"el-icon-switch-button\" command=\"logout\" divided>退出登录</el-dropdown-item>\n              </el-dropdown-menu>\n            </el-dropdown>\n          </template>\n          <template v-else>\n            <el-button type=\"primary\" size=\"small\" @click=\"$router.push('/login')\">登录</el-button>\n            <el-button size=\"small\" @click=\"$router.push('/register')\">注册</el-button>\n          </template>\n        </div>\n      </div>\n    </el-header>\n    \n    <el-main class=\"patient-main\">\n      <transition name=\"fade\" mode=\"out-in\">\n        <router-view />\n      </transition>\n    </el-main>\n    \n    <el-footer class=\"patient-footer\">\n      <div class=\"footer-content\">\n        <div class=\"footer-links\">\n          <a href=\"#\">关于我们</a>\n          <a href=\"#\">联系方式</a>\n          <a href=\"#\">帮助中心</a>\n          <a href=\"#\">隐私政策</a>\n        </div>\n        <div class=\"copyright\">\n          <p>© 2026 医院预约挂号系统 | 毕业设计作品</p>\n        </div>\n      </div>\n    </el-footer>\n  </div>\n</template>\n\n<script>\nimport { mapGetters, mapActions } from 'vuex'\n\nexport default {\n  name: 'PatientLayout',\n  computed: {\n    ...mapGetters(['token', 'username', 'nickName']),\n    activeMenu() {\n      return this.$route.path\n    }\n  },\n  methods: {\n    ...mapActions('user', ['logout']),\n    handleCommand(command) {\n      if (command === 'logout') {\n        this.$confirm('确定要退出登录吗？', '提示', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        }).then(async () => {\n          await this.logout()\n          this.$router.push('/home')\n        }).catch(() => {})\n      } else if (command === 'orders') {\n        this.$router.push('/my-orders')\n      } else if (command === 'profile') {\n        this.$router.push('/profile')\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.patient-layout {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n}\n\n.patient-header {\n  background: #fff;\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  z-index: 1000;\n  height: 60px !important;\n  \n  .header-content {\n    max-width: 1200px;\n    margin: 0 auto;\n    height: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 0 20px;\n  }\n  \n  .logo-section {\n    .logo-link {\n      display: flex;\n      align-items: center;\n      text-decoration: none;\n    }\n    \n    .logo-icon {\n      font-size: 28px;\n      color: #409EFF;\n      margin-right: 10px;\n    }\n    \n    .logo-text {\n      font-size: 18px;\n      font-weight: 600;\n      color: #409EFF;\n    }\n  }\n  \n  .nav-menu {\n    flex: 1;\n    display: flex;\n    justify-content: center;\n    border-bottom: none;\n    \n    .el-menu-item {\n      font-size: 15px;\n      padding: 0 30px;\n    }\n  }\n  \n  .user-section {\n    display: flex;\n    align-items: center;\n    \n    .el-button {\n      margin-left: 10px;\n    }\n    \n    .user-info {\n      display: flex;\n      align-items: center;\n      cursor: pointer;\n      \n      .username {\n        margin: 0 8px;\n        color: #333;\n      }\n    }\n  }\n}\n\n.patient-main {\n  flex: 1;\n  margin-top: 60px;\n  padding: 20px;\n  background: #f5f7fa;\n}\n\n.patient-footer {\n  background: #2c3e50;\n  height: auto !important;\n  padding: 30px 20px;\n  \n  .footer-content {\n    max-width: 1200px;\n    margin: 0 auto;\n    text-align: center;\n  }\n  \n  .footer-links {\n    margin-bottom: 15px;\n    \n    a {\n      color: rgba(255, 255, 255, 0.7);\n      margin: 0 20px;\n      font-size: 14px;\n      text-decoration: none;\n      transition: color 0.3s;\n      \n      &:hover {\n        color: #fff;\n      }\n    }\n  }\n  \n  .copyright {\n    color: rgba(255, 255, 255, 0.5);\n    font-size: 13px;\n  }\n}\n</style>\n"],"mappings":"AAuEA,SAAAA,UAAA,EAAAC,UAAA;AAEA;EACAC,IAAA;EACAC,QAAA;IACA,GAAAH,UAAA;IACAI,WAAA;MACA,YAAAC,MAAA,CAAAC,IAAA;IACA;EACA;EACAC,OAAA;IACA,GAAAN,UAAA;IACAO,cAAAC,OAAA;MACA,IAAAA,OAAA;QACA,KAAAC,QAAA;UACAC,iBAAA;UACAC,gBAAA;UACAC,IAAA;QACA,GAAAC,IAAA;UACA,WAAAC,MAAA;UACA,KAAAC,OAAA,CAAAC,IAAA;QACA,GAAAC,KAAA;MACA,WAAAT,OAAA;QACA,KAAAO,OAAA,CAAAC,IAAA;MACA,WAAAR,OAAA;QACA,KAAAO,OAAA,CAAAC,IAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}