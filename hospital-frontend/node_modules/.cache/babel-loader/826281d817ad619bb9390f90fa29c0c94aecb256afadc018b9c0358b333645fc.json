{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  name: 'DoctorDashboard',\n  data() {\n    return {\n      stats: {\n        todayAppointments: 12,\n        weekAppointments: 56,\n        todaySchedules: 3,\n        pendingCount: 5\n      },\n      todaySchedules: [{\n        id: 1,\n        departmentName: '内科门诊',\n        timePeriod: '上午 08:00-12:00',\n        remainingCount: 8,\n        totalCount: 20\n      }, {\n        id: 2,\n        departmentName: '内科门诊',\n        timePeriod: '下午 14:00-17:30',\n        remainingCount: 15,\n        totalCount: 20\n      }],\n      todayAppointments: [],\n      chart: null\n    };\n  },\n  mounted() {\n    this.initChart();\n    this.loadDashboardData();\n  },\n  beforeDestroy() {\n    if (this.chart) {\n      this.chart.dispose();\n    }\n  },\n  methods: {\n    initChart() {\n      this.chart = echarts.init(this.$refs.chartRef);\n      const option = {\n        tooltip: {\n          trigger: 'axis'\n        },\n        xAxis: {\n          type: 'category',\n          data: ['周一', '周二', '周三', '周四', '周五', '周六', '周日']\n        },\n        yAxis: {\n          type: 'value'\n        },\n        series: [{\n          data: [8, 12, 15, 10, 18, 6, 4],\n          type: 'line',\n          smooth: true,\n          areaStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n              offset: 0,\n              color: 'rgba(64, 158, 255, 0.5)'\n            }, {\n              offset: 1,\n              color: 'rgba(64, 158, 255, 0.1)'\n            }])\n          },\n          lineStyle: {\n            color: '#409EFF'\n          },\n          itemStyle: {\n            color: '#409EFF'\n          }\n        }]\n      };\n      this.chart.setOption(option);\n    },\n    loadDashboardData() {},\n    getStatusType(status) {\n      const types = {\n        0: 'warning',\n        1: 'primary',\n        2: 'success',\n        3: 'danger',\n        4: 'info'\n      };\n      return types[status] || 'info';\n    },\n    getStatusText(status) {\n      const texts = {\n        0: '待支付',\n        1: '已支付',\n        2: '已完成',\n        3: '已取消',\n        4: '已退款'\n      };\n      return texts[status] || '未知';\n    },\n    handleView(row) {\n      this.$message.info('查看订单: ' + row.orderNo);\n    },\n    handleComplete(row) {\n      this.$confirm('确认完成该预约?', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.$message.success('操作成功');\n      }).catch(() => {});\n    }\n  }\n};","map":{"version":3,"names":["echarts","name","data","stats","todayAppointments","weekAppointments","todaySchedules","pendingCount","id","departmentName","timePeriod","remainingCount","totalCount","chart","mounted","initChart","loadDashboardData","beforeDestroy","dispose","methods","init","$refs","chartRef","option","tooltip","trigger","xAxis","type","yAxis","series","smooth","areaStyle","color","graphic","LinearGradient","offset","lineStyle","itemStyle","setOption","getStatusType","status","types","getStatusText","texts","handleView","row","$message","info","orderNo","handleComplete","$confirm","then","success","catch"],"sources":["src/views/doctor/Dashboard.vue"],"sourcesContent":["<template>\n  <div class=\"doctor-dashboard\">\n    <el-row :gutter=\"20\" class=\"stats-row\">\n      <el-col :span=\"6\">\n        <el-card class=\"stat-card\" shadow=\"hover\">\n          <div class=\"stat-icon today\">\n            <i class=\"el-icon-date\"></i>\n          </div>\n          <div class=\"stat-info\">\n            <div class=\"stat-value\">{{ stats.todayAppointments }}</div>\n            <div class=\"stat-label\">今日预约</div>\n          </div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card class=\"stat-card\" shadow=\"hover\">\n          <div class=\"stat-icon week\">\n            <i class=\"el-icon-s-order\"></i>\n          </div>\n          <div class=\"stat-info\">\n            <div class=\"stat-value\">{{ stats.weekAppointments }}</div>\n            <div class=\"stat-label\">本周预约</div>\n          </div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card class=\"stat-card\" shadow=\"hover\">\n          <div class=\"stat-icon schedule\">\n            <i class=\"el-icon-time\"></i>\n          </div>\n          <div class=\"stat-info\">\n            <div class=\"stat-value\">{{ stats.todaySchedules }}</div>\n            <div class=\"stat-label\">今日排班</div>\n          </div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card class=\"stat-card\" shadow=\"hover\">\n          <div class=\"stat-icon pending\">\n            <i class=\"el-icon-warning\"></i>\n          </div>\n          <div class=\"stat-info\">\n            <div class=\"stat-value\">{{ stats.pendingCount }}</div>\n            <div class=\"stat-label\">待处理</div>\n          </div>\n        </el-card>\n      </el-col>\n    </el-row>\n\n    <el-row :gutter=\"20\" class=\"content-row\">\n      <el-col :span=\"16\">\n        <el-card class=\"chart-card\">\n          <div slot=\"header\">\n            <span>预约趋势（近7天）</span>\n          </div>\n          <div ref=\"chartRef\" class=\"chart-container\"></div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"8\">\n        <el-card class=\"schedule-card\">\n          <div slot=\"header\">\n            <span>今日排班</span>\n          </div>\n          <el-timeline v-if=\"todaySchedules.length > 0\">\n            <el-timeline-item\n              v-for=\"item in todaySchedules\"\n              :key=\"item.id\"\n              :timestamp=\"item.timePeriod\"\n              placement=\"top\"\n            >\n              <el-card>\n                <h4>{{ item.departmentName }}</h4>\n                <p>剩余号源: {{ item.remainingCount }}/{{ item.totalCount }}</p>\n              </el-card>\n            </el-timeline-item>\n          </el-timeline>\n          <el-empty v-else description=\"今日暂无排班\"></el-empty>\n        </el-card>\n      </el-col>\n    </el-row>\n\n    <el-row :gutter=\"20\" class=\"content-row\">\n      <el-col :span=\"24\">\n        <el-card>\n          <div slot=\"header\">\n            <span>今日预约列表</span>\n          </div>\n          <el-table :data=\"todayAppointments\" stripe style=\"width: 100%\">\n            <el-table-column prop=\"orderNo\" label=\"订单号\" width=\"180\"></el-table-column>\n            <el-table-column prop=\"patientName\" label=\"患者姓名\" width=\"120\"></el-table-column>\n            <el-table-column prop=\"departmentName\" label=\"科室\" width=\"120\"></el-table-column>\n            <el-table-column prop=\"scheduleDate\" label=\"预约日期\" width=\"120\"></el-table-column>\n            <el-table-column prop=\"timePeriod\" label=\"时段\" width=\"100\"></el-table-column>\n            <el-table-column prop=\"status\" label=\"状态\">\n              <template slot-scope=\"scope\">\n                <el-tag :type=\"getStatusType(scope.row.status)\">\n                  {{ getStatusText(scope.row.status) }}\n                </el-tag>\n              </template>\n            </el-table-column>\n            <el-table-column label=\"操作\" width=\"150\">\n              <template slot-scope=\"scope\">\n                <el-button type=\"text\" size=\"small\" @click=\"handleView(scope.row)\">查看</el-button>\n                <el-button type=\"text\" size=\"small\" @click=\"handleComplete(scope.row)\" v-if=\"scope.row.status === 1\">\n                  完成\n                </el-button>\n              </template>\n            </el-table-column>\n          </el-table>\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\n\nexport default {\n  name: 'DoctorDashboard',\n  data() {\n    return {\n      stats: {\n        todayAppointments: 12,\n        weekAppointments: 56,\n        todaySchedules: 3,\n        pendingCount: 5\n      },\n      todaySchedules: [\n        { id: 1, departmentName: '内科门诊', timePeriod: '上午 08:00-12:00', remainingCount: 8, totalCount: 20 },\n        { id: 2, departmentName: '内科门诊', timePeriod: '下午 14:00-17:30', remainingCount: 15, totalCount: 20 }\n      ],\n      todayAppointments: [],\n      chart: null\n    }\n  },\n  mounted() {\n    this.initChart()\n    this.loadDashboardData()\n  },\n  beforeDestroy() {\n    if (this.chart) {\n      this.chart.dispose()\n    }\n  },\n  methods: {\n    initChart() {\n      this.chart = echarts.init(this.$refs.chartRef)\n      const option = {\n        tooltip: {\n          trigger: 'axis'\n        },\n        xAxis: {\n          type: 'category',\n          data: ['周一', '周二', '周三', '周四', '周五', '周六', '周日']\n        },\n        yAxis: {\n          type: 'value'\n        },\n        series: [{\n          data: [8, 12, 15, 10, 18, 6, 4],\n          type: 'line',\n          smooth: true,\n          areaStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n              { offset: 0, color: 'rgba(64, 158, 255, 0.5)' },\n              { offset: 1, color: 'rgba(64, 158, 255, 0.1)' }\n            ])\n          },\n          lineStyle: {\n            color: '#409EFF'\n          },\n          itemStyle: {\n            color: '#409EFF'\n          }\n        }]\n      }\n      this.chart.setOption(option)\n    },\n    loadDashboardData() {\n    },\n    getStatusType(status) {\n      const types = { 0: 'warning', 1: 'primary', 2: 'success', 3: 'danger', 4: 'info' }\n      return types[status] || 'info'\n    },\n    getStatusText(status) {\n      const texts = { 0: '待支付', 1: '已支付', 2: '已完成', 3: '已取消', 4: '已退款' }\n      return texts[status] || '未知'\n    },\n    handleView(row) {\n      this.$message.info('查看订单: ' + row.orderNo)\n    },\n    handleComplete(row) {\n      this.$confirm('确认完成该预约?', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.$message.success('操作成功')\n      }).catch(() => {})\n    }\n  }\n}\n</script>\n\n<style scoped>\n.doctor-dashboard {\n  padding: 0;\n}\n.stats-row {\n  margin-bottom: 20px;\n}\n.stat-card {\n  display: flex;\n  align-items: center;\n  padding: 10px;\n}\n.stat-card >>> .el-card__body {\n  display: flex;\n  align-items: center;\n  width: 100%;\n}\n.stat-icon {\n  width: 60px;\n  height: 60px;\n  border-radius: 10px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-right: 15px;\n}\n.stat-icon i {\n  font-size: 28px;\n  color: #fff;\n}\n.stat-icon.today {\n  background: linear-gradient(135deg, #409EFF, #66b1ff);\n}\n.stat-icon.week {\n  background: linear-gradient(135deg, #67C23A, #85ce61);\n}\n.stat-icon.schedule {\n  background: linear-gradient(135deg, #E6A23C, #ebb563);\n}\n.stat-icon.pending {\n  background: linear-gradient(135deg, #F56C6C, #f78989);\n}\n.stat-info {\n  flex: 1;\n}\n.stat-value {\n  font-size: 28px;\n  font-weight: bold;\n  color: #303133;\n}\n.stat-label {\n  font-size: 14px;\n  color: #909399;\n  margin-top: 5px;\n}\n.chart-card {\n  height: 350px;\n}\n.chart-container {\n  height: 280px;\n}\n.schedule-card {\n  height: 350px;\n  overflow-y: auto;\n}\n.content-row {\n  margin-top: 20px;\n}\n</style>\n"],"mappings":"AAoHA,YAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,KAAA;QACAC,iBAAA;QACAC,gBAAA;QACAC,cAAA;QACAC,YAAA;MACA;MACAD,cAAA,GACA;QAAAE,EAAA;QAAAC,cAAA;QAAAC,UAAA;QAAAC,cAAA;QAAAC,UAAA;MAAA,GACA;QAAAJ,EAAA;QAAAC,cAAA;QAAAC,UAAA;QAAAC,cAAA;QAAAC,UAAA;MAAA,EACA;MACAR,iBAAA;MACAS,KAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,SAAA;IACA,KAAAC,iBAAA;EACA;EACAC,cAAA;IACA,SAAAJ,KAAA;MACA,KAAAA,KAAA,CAAAK,OAAA;IACA;EACA;EACAC,OAAA;IACAJ,UAAA;MACA,KAAAF,KAAA,GAAAb,OAAA,CAAAoB,IAAA,MAAAC,KAAA,CAAAC,QAAA;MACA,MAAAC,MAAA;QACAC,OAAA;UACAC,OAAA;QACA;QACAC,KAAA;UACAC,IAAA;UACAzB,IAAA;QACA;QACA0B,KAAA;UACAD,IAAA;QACA;QACAE,MAAA;UACA3B,IAAA;UACAyB,IAAA;UACAG,MAAA;UACAC,SAAA;YACAC,KAAA,MAAAhC,OAAA,CAAAiC,OAAA,CAAAC,cAAA,cACA;cAAAC,MAAA;cAAAH,KAAA;YAAA,GACA;cAAAG,MAAA;cAAAH,KAAA;YAAA,EACA;UACA;UACAI,SAAA;YACAJ,KAAA;UACA;UACAK,SAAA;YACAL,KAAA;UACA;QACA;MACA;MACA,KAAAnB,KAAA,CAAAyB,SAAA,CAAAf,MAAA;