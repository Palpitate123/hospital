{"ast":null,"code":"export default {\n  name: 'PatientAppointment',\n  data() {\n    return {\n      activeStep: 0,\n      queryParams: {\n        deptId: null\n      },\n      departmentList: [{\n        id: 1,\n        deptName: '内科'\n      }, {\n        id: 2,\n        deptName: '外科'\n      }, {\n        id: 3,\n        deptName: '儿科'\n      }, {\n        id: 4,\n        deptName: '妇产科'\n      }],\n      doctorList: [{\n        id: 1,\n        doctorName: '王医生',\n        deptName: '内科',\n        title: '主任医师',\n        specialty: '心血管疾病'\n      }, {\n        id: 2,\n        doctorName: '李医生',\n        deptName: '内科',\n        title: '副主任医师',\n        specialty: '呼吸系统疾病'\n      }],\n      selectedDoctor: {},\n      selectedDate: new Date(),\n      scheduleList: [{\n        id: 1,\n        scheduleDate: '2024-01-15',\n        timePeriod: 'morning',\n        remainingNumber: 8\n      }, {\n        id: 2,\n        scheduleDate: '2024-01-15',\n        timePeriod: 'afternoon',\n        remainingNumber: 15\n      }],\n      selectedSchedule: null,\n      selectedScheduleInfo: {},\n      patientForm: {\n        patientName: '',\n        patientIdCard: '',\n        patientPhone: '',\n        remark: ''\n      },\n      patientRules: {\n        patientName: [{\n          required: true,\n          message: '请输入患者姓名',\n          trigger: 'blur'\n        }],\n        patientIdCard: [{\n          required: true,\n          message: '请输入身份证号',\n          trigger: 'blur'\n        }],\n        patientPhone: [{\n          required: true,\n          message: '请输入联系电话',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    const doctorId = this.$route.query.doctorId;\n    if (doctorId) {\n      this.selectedDoctor = {\n        id: doctorId,\n        doctorName: '王医生',\n        deptName: '内科',\n        title: '主任医师'\n      };\n      this.activeStep = 1;\n    }\n  },\n  methods: {\n    handleDeptChange() {\n      this.loadDoctors();\n    },\n    loadDoctors() {},\n    handleDoctorSelect(row) {\n      this.selectedDoctor = row;\n    },\n    hasSchedule(day) {\n      return true;\n    },\n    handleDateSelect(day) {\n      this.loadSchedules(day);\n    },\n    loadSchedules(date) {},\n    prevStep() {\n      this.activeStep--;\n    },\n    nextStep() {\n      if (this.activeStep === 0 && !this.selectedDoctor.id) {\n        this.$message.warning('请选择医生');\n        return;\n      }\n      if (this.activeStep === 1 && !this.selectedSchedule) {\n        this.$message.warning('请选择时段');\n        return;\n      }\n      if (this.activeStep === 2) {\n        this.$refs.patientFormRef.validate(valid => {\n          if (valid) {\n            this.activeStep++;\n          }\n        });\n        return;\n      }\n      this.activeStep++;\n    },\n    handleSubmit() {\n      this.$confirm('确认提交预约?', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.$message.success('预约成功');\n        this.$router.push('/patient/my-orders');\n      }).catch(() => {});\n    }\n  }\n};","map":{"version":3,"names":["name","data","activeStep","queryParams","deptId","departmentList","id","deptName","doctorList","doctorName","title","specialty","selectedDoctor","selectedDate","Date","scheduleList","scheduleDate","timePeriod","remainingNumber","selectedSchedule","selectedScheduleInfo","patientForm","patientName","patientIdCard","patientPhone","remark","patientRules","required","message","trigger","created","doctorId","$route","query","methods","handleDeptChange","loadDoctors","handleDoctorSelect","row","hasSchedule","day","handleDateSelect","loadSchedules","date","prevStep","nextStep","$message","warning","$refs","patientFormRef","validate","valid","handleSubmit","$confirm","type","then","success","$router","push","catch"],"sources":["src/views/patient/Appointment.vue"],"sourcesContent":["<template>\n  <div class=\"patient-appointment\">\n    <el-breadcrumb separator=\"/\" class=\"breadcrumb\">\n      <el-breadcrumb-item :to=\"{ path: '/patient/home' }\">首页</el-breadcrumb-item>\n      <el-breadcrumb-item>预约挂号</el-breadcrumb-item>\n    </el-breadcrumb>\n\n    <el-card class=\"step-card\">\n      <el-steps :active=\"activeStep\" finish-status=\"success\" simple>\n        <el-step title=\"选择医生\"></el-step>\n        <el-step title=\"选择时间\"></el-step>\n        <el-step title=\"填写信息\"></el-step>\n        <el-step title=\"确认预约\"></el-step>\n      </el-steps>\n    </el-card>\n\n    <el-card v-if=\"activeStep === 0\" class=\"content-card\">\n      <div slot=\"header\">\n        <span>选择医生</span>\n      </div>\n      <el-form :inline=\"true\" class=\"search-form\">\n        <el-form-item label=\"科室\">\n          <el-select v-model=\"queryParams.deptId\" placeholder=\"请选择科室\" @change=\"handleDeptChange\">\n            <el-option v-for=\"dept in departmentList\" :key=\"dept.id\" :label=\"dept.deptName\" :value=\"dept.id\"></el-option>\n          </el-select>\n        </el-form-item>\n      </el-form>\n      <el-table :data=\"doctorList\" style=\"width: 100%\" highlight-current-row @current-change=\"handleDoctorSelect\">\n        <el-table-column prop=\"doctorName\" label=\"医生姓名\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"deptName\" label=\"科室\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"title\" label=\"职称\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"specialty\" label=\"擅长\"></el-table-column>\n      </el-table>\n    </el-card>\n\n    <el-card v-if=\"activeStep === 1\" class=\"content-card\">\n      <div slot=\"header\">\n        <span>选择时间 - {{ selectedDoctor.doctorName }}</span>\n      </div>\n      <el-calendar v-model=\"selectedDate\">\n        <template slot=\"dateCell\" slot-scope=\"{date, data}\">\n          <div class=\"calendar-cell\" @click=\"handleDateSelect(data.day)\">\n            {{ data.day.split('-')[2] }}\n            <div v-if=\"hasSchedule(data.day)\" class=\"schedule-dot\"></div>\n          </div>\n        </template>\n      </el-calendar>\n      <div class=\"time-slots\" v-if=\"scheduleList.length > 0\">\n        <h4>选择时段</h4>\n        <el-radio-group v-model=\"selectedSchedule\">\n          <el-radio \n            v-for=\"schedule in scheduleList\" \n            :key=\"schedule.id\" \n            :label=\"schedule.id\"\n            :disabled=\"schedule.remainingNumber <= 0\"\n            border\n          >\n            {{ schedule.timePeriod === 'morning' ? '上午' : '下午' }} (剩余{{ schedule.remainingNumber }}号)\n          </el-radio>\n        </el-radio-group>\n      </div>\n    </el-card>\n\n    <el-card v-if=\"activeStep === 2\" class=\"content-card\">\n      <div slot=\"header\">\n        <span>填写患者信息</span>\n      </div>\n      <el-form :model=\"patientForm\" :rules=\"patientRules\" ref=\"patientFormRef\" label-width=\"100px\" style=\"max-width: 500px\">\n        <el-form-item label=\"患者姓名\" prop=\"patientName\">\n          <el-input v-model=\"patientForm.patientName\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"身份证号\" prop=\"patientIdCard\">\n          <el-input v-model=\"patientForm.patientIdCard\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"联系电话\" prop=\"patientPhone\">\n          <el-input v-model=\"patientForm.patientPhone\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"备注\">\n          <el-input type=\"textarea\" v-model=\"patientForm.remark\" rows=\"3\"></el-input>\n        </el-form-item>\n      </el-form>\n    </el-card>\n\n    <el-card v-if=\"activeStep === 3\" class=\"content-card\">\n      <div slot=\"header\">\n        <span>确认预约信息</span>\n      </div>\n      <el-descriptions :column=\"2\" border>\n        <el-descriptions-item label=\"医生\">{{ selectedDoctor.doctorName }}</el-descriptions-item>\n        <el-descriptions-item label=\"科室\">{{ selectedDoctor.deptName }}</el-descriptions-item>\n        <el-descriptions-item label=\"预约日期\">{{ selectedScheduleInfo.scheduleDate }}</el-descriptions-item>\n        <el-descriptions-item label=\"时段\">{{ selectedScheduleInfo.timePeriod === 'morning' ? '上午' : '下午' }}</el-descriptions-item>\n        <el-descriptions-item label=\"患者姓名\">{{ patientForm.patientName }}</el-descriptions-item>\n        <el-descriptions-item label=\"联系电话\">{{ patientForm.patientPhone }}</el-descriptions-item>\n        <el-descriptions-item label=\"身份证号\" :span=\"2\">{{ patientForm.patientIdCard }}</el-descriptions-item>\n        <el-descriptions-item label=\"备注\" :span=\"2\">{{ patientForm.remark || '无' }}</el-descriptions-item>\n      </el-descriptions>\n    </el-card>\n\n    <div class=\"action-buttons\">\n      <el-button v-if=\"activeStep > 0\" @click=\"prevStep\">上一步</el-button>\n      <el-button v-if=\"activeStep < 3\" type=\"primary\" @click=\"nextStep\">下一步</el-button>\n      <el-button v-if=\"activeStep === 3\" type=\"success\" @click=\"handleSubmit\">确认预约</el-button>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'PatientAppointment',\n  data() {\n    return {\n      activeStep: 0,\n      queryParams: {\n        deptId: null\n      },\n      departmentList: [\n        { id: 1, deptName: '内科' },\n        { id: 2, deptName: '外科' },\n        { id: 3, deptName: '儿科' },\n        { id: 4, deptName: '妇产科' }\n      ],\n      doctorList: [\n        { id: 1, doctorName: '王医生', deptName: '内科', title: '主任医师', specialty: '心血管疾病' },\n        { id: 2, doctorName: '李医生', deptName: '内科', title: '副主任医师', specialty: '呼吸系统疾病' }\n      ],\n      selectedDoctor: {},\n      selectedDate: new Date(),\n      scheduleList: [\n        { id: 1, scheduleDate: '2024-01-15', timePeriod: 'morning', remainingNumber: 8 },\n        { id: 2, scheduleDate: '2024-01-15', timePeriod: 'afternoon', remainingNumber: 15 }\n      ],\n      selectedSchedule: null,\n      selectedScheduleInfo: {},\n      patientForm: {\n        patientName: '',\n        patientIdCard: '',\n        patientPhone: '',\n        remark: ''\n      },\n      patientRules: {\n        patientName: [{ required: true, message: '请输入患者姓名', trigger: 'blur' }],\n        patientIdCard: [{ required: true, message: '请输入身份证号', trigger: 'blur' }],\n        patientPhone: [{ required: true, message: '请输入联系电话', trigger: 'blur' }]\n      }\n    }\n  },\n  created() {\n    const doctorId = this.$route.query.doctorId\n    if (doctorId) {\n      this.selectedDoctor = { id: doctorId, doctorName: '王医生', deptName: '内科', title: '主任医师' }\n      this.activeStep = 1\n    }\n  },\n  methods: {\n    handleDeptChange() {\n      this.loadDoctors()\n    },\n    loadDoctors() {\n    },\n    handleDoctorSelect(row) {\n      this.selectedDoctor = row\n    },\n    hasSchedule(day) {\n      return true\n    },\n    handleDateSelect(day) {\n      this.loadSchedules(day)\n    },\n    loadSchedules(date) {\n    },\n    prevStep() {\n      this.activeStep--\n    },\n    nextStep() {\n      if (this.activeStep === 0 && !this.selectedDoctor.id) {\n        this.$message.warning('请选择医生')\n        return\n      }\n      if (this.activeStep === 1 && !this.selectedSchedule) {\n        this.$message.warning('请选择时段')\n        return\n      }\n      if (this.activeStep === 2) {\n        this.$refs.patientFormRef.validate(valid => {\n          if (valid) {\n            this.activeStep++\n          }\n        })\n        return\n      }\n      this.activeStep++\n    },\n    handleSubmit() {\n      this.$confirm('确认提交预约?', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.$message.success('预约成功')\n        this.$router.push('/patient/my-orders')\n      }).catch(() => {})\n    }\n  }\n}\n</script>\n\n<style scoped>\n.patient-appointment {\n  padding: 20px;\n}\n.breadcrumb {\n  margin-bottom: 20px;\n}\n.step-card {\n  margin-bottom: 20px;\n}\n.content-card {\n  margin-bottom: 20px;\n}\n.search-form {\n  margin-bottom: 20px;\n}\n.calendar-cell {\n  position: relative;\n  height: 100%;\n  cursor: pointer;\n}\n.schedule-dot {\n  position: absolute;\n  bottom: 5px;\n  left: 50%;\n  transform: translateX(-50%);\n  width: 6px;\n  height: 6px;\n  background: #67C23A;\n  border-radius: 50%;\n}\n.time-slots {\n  margin-top: 20px;\n}\n.time-slots h4 {\n  margin-bottom: 15px;\n}\n.time-slots .el-radio {\n  margin-right: 15px;\n  margin-bottom: 10px;\n}\n.action-buttons {\n  text-align: center;\n  margin-top: 20px;\n}\n</style>\n"],"mappings":"AA4GA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,UAAA;MACAC,WAAA;QACAC,MAAA;MACA;MACAC,cAAA,GACA;QAAAC,EAAA;QAAAC,QAAA;MAAA,GACA;QAAAD,EAAA;QAAAC,QAAA;MAAA,GACA;QAAAD,EAAA;QAAAC,QAAA;MAAA,GACA;QAAAD,EAAA;QAAAC,QAAA;MAAA,EACA;MACAC,UAAA,GACA;QAAAF,EAAA;QAAAG,UAAA;QAAAF,QAAA;QAAAG,KAAA;QAAAC,SAAA;MAAA,GACA;QAAAL,EAAA;QAAAG,UAAA;QAAAF,QAAA;QAAAG,KAAA;QAAAC,SAAA;MAAA,EACA;MACAC,cAAA;MACAC,YAAA,MAAAC,IAAA;MACAC,YAAA,GACA;QAAAT,EAAA;QAAAU,YAAA;QAAAC,UAAA;QAAAC,eAAA;MAAA,GACA;QAAAZ,EAAA;QAAAU,YAAA;QAAAC,UAAA;QAAAC,eAAA;MAAA,EACA;MACAC,gBAAA;MACAC,oBAAA;MACAC,WAAA;QACAC,WAAA;QACAC,aAAA;QACAC,YAAA;QACAC,MAAA;MACA;MACAC,YAAA;QACAJ,WAAA;UAAAK,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAN,aAAA;UAAAI,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAL,YAAA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,MAAAC,QAAA,QAAAC,MAAA,CAAAC,KAAA,CAAAF,QAAA;IACA,IAAAA,QAAA;MACA,KAAAnB,cAAA;QAAAN,EAAA,EAAAyB,QAAA;QAAAtB,UAAA;QAAAF,QAAA;QAAAG,KAAA;MAAA;MACA,KAAAR,UAAA;IACA;EACA;EACAgC,OAAA;IACAC,iBAAA;MACA,KAAAC,WAAA;IACA;IACAA,YAAA,GACA;IACAC,mBAAAC,GAAA;MACA,KAAA1B,cAAA,GAAA0B,GAAA;IACA;IACAC,YAAAC,GAAA;MACA;IACA;IACAC,iBAAAD,GAAA;MACA,KAAAE,aAAA,CAAAF,GAAA;IACA;IACAE,cAAAC,IAAA,GACA;IACAC,SAAA;MACA,KAAA1C,UAAA;IACA;IACA2C,SAAA;MACA,SAAA3C,UAAA,gBAAAU,cAAA,CAAAN,EAAA;QACA,KAAAwC,QAAA,CAAAC,OAAA;QACA;MACA;MACA,SAAA7C,UAAA,gBAAAiB,gBAAA;QACA,KAAA2B,QAAA,CAAAC,OAAA;QACA;MACA;MACA,SAAA7C,UAAA;QACA,KAAA8C,KAAA,CAAAC,cAAA,CAAAC,QAAA,CAAAC,KAAA;UACA,IAAAA,KAAA;YACA,KAAAjD,UAAA;UACA;QACA;QACA;MACA;MACA,KAAAA,UAAA;IACA;IACAkD,aAAA;MACA,KAAAC,QAAA;QACAC,IAAA;MACA,GAAAC,IAAA;QACA,KAAAT,QAAA,CAAAU,OAAA;QACA,KAAAC,OAAA,CAAAC,IAAA;MACA,GAAAC,KAAA;IACA;EACA