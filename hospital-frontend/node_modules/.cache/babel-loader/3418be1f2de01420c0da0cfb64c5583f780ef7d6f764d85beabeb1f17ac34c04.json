{"ast":null,"code":"import { mapGetters, mapActions } from 'vuex';\nexport default {\n  name: 'AdminLayout',\n  data() {\n    return {\n      isCollapse: false\n    };\n  },\n  computed: {\n    ...mapGetters(['username']),\n    activeMenu() {\n      return this.$route.path;\n    }\n  },\n  methods: {\n    ...mapActions('user', ['logout']),\n    toggleCollapse() {\n      this.isCollapse = !this.isCollapse;\n    },\n    handleCommand(command) {\n      if (command === 'logout') {\n        this.$confirm('确定要退出登录吗？', '提示', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        }).then(async () => {\n          await this.logout();\n          this.$router.push('/login');\n        }).catch(() => {});\n      } else if (command === 'profile') {\n        this.$message.info('个人信息功能开发中');\n      }\n    }\n  }\n};","map":{"version":3,"names":["mapGetters","mapActions","name","data","isCollapse","computed","activeMenu","$route","path","methods","toggleCollapse","handleCommand","command","$confirm","confirmButtonText","cancelButtonText","type","then","logout","$router","push","catch","$message","info"],"sources":["src/views/layout/AdminLayout.vue"],"sourcesContent":["<template>\n  <div class=\"admin-layout\">\n    <el-container>\n      <el-aside :width=\"isCollapse ? '64px' : '220px'\" class=\"admin-aside\">\n        <div class=\"logo-container\">\n          <i class=\"el-icon-first-aid-kit logo-icon\" v-if=\"!isCollapse\"></i>\n          <span class=\"logo-text\" v-if=\"!isCollapse\">医院预约挂号系统</span>\n          <span class=\"logo-mini\" v-else>H</span>\n        </div>\n        \n        <el-menu\n          :default-active=\"activeMenu\"\n          :collapse=\"isCollapse\"\n          :collapse-transition=\"false\"\n          background-color=\"#304156\"\n          text-color=\"#bfcbd9\"\n          active-text-color=\"#409EFF\"\n          router\n        >\n          <el-menu-item index=\"/admin/dashboard\">\n            <i class=\"el-icon-s-home\"></i>\n            <span slot=\"title\">后台首页</span>\n          </el-menu-item>\n          \n          <el-menu-item index=\"/admin/department\">\n            <i class=\"el-icon-office-building\"></i>\n            <span slot=\"title\">科室管理</span>\n          </el-menu-item>\n          \n          <el-menu-item index=\"/admin/doctor\">\n            <i class=\"el-icon-user\"></i>\n            <span slot=\"title\">医生管理</span>\n          </el-menu-item>\n          \n          <el-menu-item index=\"/admin/schedule\">\n            <i class=\"el-icon-date\"></i>\n            <span slot=\"title\">排班管理</span>\n          </el-menu-item>\n          \n          <el-menu-item index=\"/admin/user\">\n            <i class=\"el-icon-s-custom\"></i>\n            <span slot=\"title\">用户管理</span>\n          </el-menu-item>\n          \n          <el-menu-item index=\"/admin/order\">\n            <i class=\"el-icon-document\"></i>\n            <span slot=\"title\">订单管理</span>\n          </el-menu-item>\n        </el-menu>\n      </el-aside>\n      \n      <el-container>\n        <el-header class=\"admin-header\">\n          <div class=\"header-left\">\n            <i\n              :class=\"isCollapse ? 'el-icon-s-unfold' : 'el-icon-s-fold'\"\n              class=\"collapse-btn\"\n              @click=\"toggleCollapse\"\n            ></i>\n            <el-breadcrumb separator=\"/\">\n              <el-breadcrumb-item :to=\"{ path: '/admin/dashboard' }\">首页</el-breadcrumb-item>\n              <el-breadcrumb-item v-if=\"$route.meta.title\">{{ $route.meta.title }}</el-breadcrumb-item>\n            </el-breadcrumb>\n          </div>\n          \n          <div class=\"header-right\">\n            <el-dropdown @command=\"handleCommand\">\n              <span class=\"user-info\">\n                <el-avatar :size=\"32\" icon=\"el-icon-user-solid\"></el-avatar>\n                <span class=\"username\">{{ username }}</span>\n                <i class=\"el-icon-arrow-down\"></i>\n              </span>\n              <el-dropdown-menu slot=\"dropdown\">\n                <el-dropdown-item icon=\"el-icon-user\" command=\"profile\">个人信息</el-dropdown-item>\n                <el-dropdown-item icon=\"el-icon-switch-button\" command=\"logout\" divided>退出登录</el-dropdown-item>\n              </el-dropdown-menu>\n            </el-dropdown>\n          </div>\n        </el-header>\n        \n        <el-main class=\"admin-main\">\n          <transition name=\"fade\" mode=\"out-in\">\n            <router-view />\n          </transition>\n        </el-main>\n      </el-container>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport { mapGetters, mapActions } from 'vuex'\n\nexport default {\n  name: 'AdminLayout',\n  data() {\n    return {\n      isCollapse: false\n    }\n  },\n  computed: {\n    ...mapGetters(['username']),\n    activeMenu() {\n      return this.$route.path\n    }\n  },\n  methods: {\n    ...mapActions('user', ['logout']),\n    toggleCollapse() {\n      this.isCollapse = !this.isCollapse\n    },\n    handleCommand(command) {\n      if (command === 'logout') {\n        this.$confirm('确定要退出登录吗？', '提示', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        }).then(async () => {\n          await this.logout()\n          this.$router.push('/login')\n        }).catch(() => {})\n      } else if (command === 'profile') {\n        this.$message.info('个人信息功能开发中')\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.admin-layout {\n  height: 100vh;\n  \n  .el-container {\n    height: 100%;\n  }\n}\n\n.admin-aside {\n  background-color: #304156;\n  transition: width 0.3s;\n  overflow: hidden;\n  \n  .logo-container {\n    height: 60px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background-color: #263445;\n    overflow: hidden;\n    \n    .logo-icon {\n      font-size: 28px;\n      color: #409EFF;\n      margin-right: 10px;\n    }\n    \n    .logo-text {\n      color: #fff;\n      font-size: 16px;\n      font-weight: 600;\n      white-space: nowrap;\n    }\n    \n    .logo-mini {\n      color: #fff;\n      font-size: 24px;\n      font-weight: bold;\n    }\n  }\n  \n  .el-menu {\n    border-right: none;\n  }\n}\n\n.admin-header {\n  background-color: #fff;\n  box-shadow: 0 1px 4px rgba(0, 21, 41, 0.08);\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 0 20px;\n  \n  .header-left {\n    display: flex;\n    align-items: center;\n    \n    .collapse-btn {\n      font-size: 20px;\n      cursor: pointer;\n      margin-right: 15px;\n      color: #606266;\n      \n      &:hover {\n        color: #409EFF;\n      }\n    }\n  }\n  \n  .header-right {\n    .user-info {\n      display: flex;\n      align-items: center;\n      cursor: pointer;\n      \n      .username {\n        margin: 0 8px;\n        color: #606266;\n      }\n    }\n  }\n}\n\n.admin-main {\n  background-color: #f0f2f5;\n  padding: 20px;\n  overflow-y: auto;\n}\n</style>\n"],"mappings":"AA2FA,SAAAA,UAAA,EAAAC,UAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,UAAA;IACA;EACA;EACAC,QAAA;IACA,GAAAL,UAAA;IACAM,WAAA;MACA,YAAAC,MAAA,CAAAC,IAAA;IACA;EACA;EACAC,OAAA;IACA,GAAAR,UAAA;IACAS,eAAA;MACA,KAAAN,UAAA,SAAAA,UAAA;IACA;IACAO,cAAAC,OAAA;MACA,IAAAA,OAAA;QACA,KAAAC,QAAA;UACAC,iBAAA;UACAC,gBAAA;UACAC,IAAA;QACA,GAAAC,IAAA;UACA,WAAAC,MAAA;UACA,KAAAC,OAAA,CAAAC,IAAA;QACA,GAAAC,KAAA;MACA,WAAAT,OAAA;QACA,KAAAU,QAAA,CAAAC,IAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}